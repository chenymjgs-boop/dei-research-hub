# ============= LLM / OpenAI API =============
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxx
# Optional: override default model
OPENAI_MODEL=gpt-5.4-mini
# Avoid 429s on low-TPM OpenAI projects. Set lower after rate limit increases.
LLM_REQUEST_DELAY_SECONDS=25

# Optional fallback: Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Optional: override default model
CLAUDE_MODEL=claude-sonnet-4-6

# ============= Feishu / Lark =============
# 在飞书开放平台创建自建应用后获得：https://open.feishu.cn/
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格 (Bitable) 用于存储所有研究条目
# 在飞书中创建一个多维表格，URL 形如：https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 群聊 chat_id 用于推送每日摘要消息（可选）
# 通过机器人 @获取chat_id 或 API: /im/v1/chats 查询
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxx

# 云文档（用于周报/月报输出）—— 父文件夹 token，可选
FEISHU_DOC_FOLDER_TOKEN=

# ============= 微信公众号三层方案 (Phase 3c+) =============
# Layer 1 · Wechat2RSS 公开服务: 直接在 src/sources/registry.py 配 feed URL
# 私有部署时填 base URL（可选）
WECHAT2RSS_PRIVATE_BASE_URL=

# Layer 2 · 自建 WeWe RSS Docker 实例（Phase 3d 才会用）
WEWERSS_BASE_URL=
WEWERSS_AUTH_CODE=
WEWERSS_HEALTH_CHECK_ENABLED=true

# Layer 3 · 飞书人工链接搬运（Phase 3c 用）
# 接收公众号链接的飞书群 chat_id（可与主推送群不同）
FEISHU_MANUAL_INTAKE_CHAT_ID=

# ============= 任务参数 =============
# 每日抓取的最大条目数（v2 来源变多，从 40 提到 50）
MAX_ITEMS_PER_RUN=50
# 单源最多保留多少条进入 LLM 处理
MAX_ITEMS_PER_SOURCE=8
# 文章发布时间窗口（天），超过此窗口的不再抓取
LOOKBACK_DAYS=7

# ============= 客户视角权重 (v2) =============
# 用于 client_score 排序与每日卡片优先级。可按业务侧重调整。
WEIGHT_MNC_IN_CHINA=1.0
WEIGHT_ESG_LISTING=1.0
WEIGHT_GOING_GLOBAL=1.2
