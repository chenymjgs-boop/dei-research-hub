# ============= Claude API =============
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Optional: override default model
CLAUDE_MODEL=claude-opus-4-6

# ============= Feishu / Lark =============
# 在飞书开放平台创建自建应用后获得：https://open.feishu.cn/
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表格 (Bitable) 用于存储所有研究条目
# 在飞书中创建一个多维表格，URL 形如：https://xxx.feishu.cn/base/<APP_TOKEN>?table=<TABLE_ID>
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxxxx
FEISHU_BITABLE_TABLE_ID=tblxxxxxxxxxxxxxxxx

# 群聊 chat_id 用于推送每日摘要消息（可选）
# 通过机器人 @获取chat_id 或 API: /im/v1/chats 查询
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxx

# 云文档（用于周报/月报输出）—— 父文件夹 token，可选
FEISHU_DOC_FOLDER_TOKEN=

# ============= 任务参数 =============
# 每日抓取的最大条目数（防止过量）
MAX_ITEMS_PER_RUN=40
# 单源最多保留多少条进入 LLM 处理
MAX_ITEMS_PER_SOURCE=8
# 文章发布时间窗口（天），超过此窗口的不再抓取
LOOKBACK_DAYS=7
